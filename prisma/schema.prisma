generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Event {
  id          String     @id @default(uuid())
  title       String
  description String
  date        DateTime
  capacity    Int
  address     String
  city        String
  createdAt   DateTime   @default(now())

  attendees   Attendee[]
}

model Attendee {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  eventId   String
  createdAt DateTime @default(now())

  event     Event @relation(fields: [eventId], references: [id])
}

